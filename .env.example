# OAuth 2.1 / OIDC provider settings.
BILLAR_OAUTH_CLIENT_ID=
BILLAR_OAUTH_CLIENT_SECRET=
BILLAR_OAUTH_ISSUER_URL=

# Protected resource metadata URI.
BILLAR_AUTH_RESOURCE_SERVER_URI=https://billar.local

# Access policy allowlists (comma-separated, trimmed).
BILLAR_AUTH_ALLOWED_EMAILS=user@example.com
BILLAR_AUTH_ALLOWED_DOMAINS=company.com

# MCP session ingress policy.
ALLOWED_EMAILS=user@example.com
ALLOWED_DOMAINS=company.com
ALLOWED_IPS=127.0.0.1
OAUTH_PROVIDER=openai
