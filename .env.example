LOG_LEVEL=info

# MCP HTTP API key authentication (replaces OAuth/OIDC).
# Set one or more comma-separated keys. Startup fails if not set.
MCP_API_KEYS=your-secret-api-key-here

# Local mcp-http server runtime.
MCP_HTTP_LISTEN_ADDR=127.0.0.1:8080

# Root directory for MCP file-output tools such as invoice.render_pdf.
BILLAR_EXPORT_DIR=/tmp/billar-exports

# Optional SQLite database override. Leave unset to use the persistent default:
# $XDG_DATA_HOME/billar/billar.db, then os.UserConfigDir()/billar/billar.db,
# then ~/.local/share/billar/billar.db.
# BILLAR_DB_PATH=/absolute/path/to/billar.db
