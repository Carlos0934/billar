# OAuth 2.1 / OIDC provider settings.
LOG_LEVEL=info

OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
OAUTH_ISSUER_URL=https://accounts.google.com

# Local mcp-http server runtime.
MCP_HTTP_LISTEN_ADDR=127.0.0.1:8080

# Protected resource metadata URI.
AUTH_RESOURCE_SERVER_URI=http://127.0.0.1:8080

# Access policy allowlists (comma-separated, trimmed).
AUTH_ALLOWED_EMAILS=user@example.com
AUTH_ALLOWED_DOMAINS=company.com

# MCP session ingress policy.
ALLOWED_EMAILS=user@example.com
ALLOWED_DOMAINS=company.com
ALLOWED_IPS=127.0.0.1
OAUTH_PROVIDER=openai

# Explicit local bypass for CLI and stdio-only protected operations.
BILLAR_LOCAL_AUTH_EMAIL=user@example.com
